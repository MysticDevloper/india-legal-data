  "quick_guide": {
    "title": "Quick Action Guide - What to do in different situations",
    "scenarios": [
      {
        "situation": "Theft/Burglary",
        "steps": [
          "1. File FIR online at your state police portal OR visit nearest police station",
          "2. Get FIR copy with FIR number",
          "3. For insurance: submit FIR copy to insurer"
        ],
        "portals": ["https://delhipolice.gov.in", "https://citizen.mahapolice.gov.in"]
      },
      {
        "situation": "Cyber Fraud/Scam",
        "steps": [
          "1. Immediately call your bank to block transaction",
          "2. File complaint at cybercrime.gov.in",
          "3. Save acknowledgment number",
          "4. File police complaint at local station with proof"
        ],
        "portals": ["https://cybercrime.gov.in", "https://pgportal.gov.in"]
      },
      {
        "situation": "Domestic Violence",
        "steps": [
          "1. Call women's helpline 181",
          "2. File complaint at local police station",
          "3. Apply for protection order at local court",
          "4. Contact District Legal Services Authority for free lawyer"
        ],
        "portals": ["https://nalsa.gov.in/womens-assistance/", "https://nalsa.gov.in"]
      },
      {
        "situation": "Police Not Taking Action",
        "steps": [
          "1. Wait 7 days for response",
          "2. File written complaint to SP/Commissioner",
          "3. If no action in 30 days, file complaint on CPGRAMS",
          "4. Contact Human Rights Commission if serious"
        ],
        "portals": ["https://pgportal.gov.in", "https://nhrc.nic.in"]
      },
      {
        "situation": "Can't Afford Lawyer",
        "steps": [
          "1. Call legal aid helpline 15100",
          "2. Apply online at nalsa.gov.in",
          "3. Or visit nearest District Legal Services Authority office",
          "4. Free lawyer will be provided"
        ],
        "portals": ["https://nalsa.gov.in/services/legal-aid"]
      },
      {
        "situation": "Lost Documents",
        "steps": [
          "1. File 'Lost Report' at state police portal",
          "2. Get acknowledgment with reference number",
          "3. Use this for new document application",
          "4. Some portals: https://lostdocument.gov.in"
        ],
        "portals": ["https://digitalpolice.gov.in"]
      },
      {
        "situation": "Landlord/Tenant Dispute",
        "steps": [
          "1. Send legal notice (can use free legal aid)",
          "2. File complaint at Rent Control Court",
          "3. Contact Legal Services for mediator"
        ],
        "portals": ["https://nalsa.gov.in/lok-adalat"]
      },
      {
        "situation": "Workplace Harassment (POSH)",
        "steps": [
          "1. File written complaint to Internal Committee",
          "2. If no response in 10 days, file with Local Committee",
          "3. Contact police if needed",
          "4. Contact NALSA for legal aid"
        ],
        "portals": ["https://nalsa.gov.in/posh/"]
      },
      {
        "situation": "Child Missing/Abuse",
        "steps": [
          "1. Call Child Helpline 1098 immediately",
          "2. File FIR mentioning child details and incident",
          "3. Police must register Zero FIR in any jurisdiction",
          "4. Contact CHILDLINE for support"
        ],
        "portals": ["https://cybercrime.gov.in/webform/cybercrime_women_child.aspx"]
      },
      {
        "situation": "Accident/Road Rage",
        "steps": [
          "1. Call 112 for emergency",
          "2. Click photos/video if safe",
          "3. Note vehicle number if vehicle involved",
          "4. File complaint with video evidence"
        ],
        "portals": ["https://digitalpolice.gov.in"]
      }
    ]
  }
